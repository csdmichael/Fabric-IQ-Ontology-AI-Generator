PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# ---- Cosmos DB ----
COSMOS_ENDPOINT=https://cosmos-fabriciq-demo-01.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=fabric-iq
COSMOS_CONTAINER=ontologies
COSMOS_USERS_CONTAINER=users
COSMOS_LOGIN_AUDIT_CONTAINER=login-audit

# ---- Blob storage (aistoragemyaacoub) ----
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_ACCOUNT_NAME=aistoragemyaacoub
AZURE_STORAGE_CONTAINER=fabric-iq-prompts
AZURE_STORAGE_ONTOLOGY_CONTAINER=fabric-ontologies

# ---- Microsoft Fabric ----
FABRIC_WORKSPACE_ID=2b2c447d-86e1-4982-a5b6-09d2e0f3482d
FABRIC_CAPACITY_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=
FABRIC_TENANT_ID=b158173c-91f6-4f99-b5e9-aa9bcb463863
FABRIC_LAKEHOUSE_ID=

# ---- OpenAI / Azure OpenAI ----
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=fabric-iq-generator

# ---- Authentication (OTP + Entra ID) ----
JWT_SECRET=replace-with-a-long-random-string
JWT_ISSUER=fabric-iq-api
JWT_AUDIENCE=fabric-iq-ui
JWT_TTL_SECONDS=28800
OTP_TTL_SECONDS=600
OTP_LENGTH=6
AUTH_ALLOWED_ENTRA_DOMAIN=@MngEnvMCAP829495.onmicrosoft.com
AZURE_TENANT_ID=b158173c-91f6-4f99-b5e9-aa9bcb463863
ENTRA_TENANT_ID=b158173c-91f6-4f99-b5e9-aa9bcb463863
ENTRA_CLIENT_ID=
ENTRA_ISSUER=https://login.microsoftonline.com/b158173c-91f6-4f99-b5e9-aa9bcb463863/v2.0
ENTRA_JWKS_URI=https://login.microsoftonline.com/b158173c-91f6-4f99-b5e9-aa9bcb463863/discovery/v2.0/keys

# ---- Azure Communication Services Email (fabriciq-shortages-email-b3) ----
ACS_CONNECTION_STRING=
